					<dc:identifier>http://www.legislation.gov.uk/uksi/2015/980/regulation/2/made</dc:identifier><dc:title>The Companies, Partnerships and Groups (Accounts and Reports) Regulations 2015</dc:title><dc:language>en</dc:language><dc:publisher>King's Printer of Acts of Parliament</dc:publisher><dc:modified>2023-05-11</dc:modified><dc:subject scheme="SIheading">COMPANIES</dc:subject><dc:subject scheme="SIheading">PARTNERSHIP</dc:subject>
